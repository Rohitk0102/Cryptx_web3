# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Get from your PostgreSQL provider (Supabase, Neon, Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/cryptx"

# Redis Configuration
# Get from your Redis provider (Upstash, Redis Cloud)
REDIS_URL="redis://localhost:6379"

# JWT Configuration
# Generate secure random strings (32 characters recommended)
JWT_SECRET="local-dev-jwt-secret-change-me-1234"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="local-dev-refresh-secret-change-me"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Encryption Configuration
# MUST be exactly 32 characters
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# Exchange API Encryption
# 32-byte key (64 hex characters) for AES-256-GCM encryption of exchange API credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXCHANGE_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# CoinDCX Portfolio API
# Used by the dedicated /api/balances, /api/trades and unauthenticated /api/portfolio endpoints.
COINDCX_API_KEY=""
COINDCX_API_SECRET=""
COINDCX_BASE_URL="https://api.coindcx.com"

# Blockchain RPC URLs
# You can provide a single URL or a comma-separated list for automatic failover.
# Prefer provider URLs you control (Alchemy, Infura, QuickNode); public RPCs are best-effort fallbacks.
ETH_RPC_URL="https://eth.llamarpc.com,https://ethereum-rpc.publicnode.com"
POLYGON_RPC_URL="https://polygon-bor-rpc.publicnode.com,https://polygon.llamarpc.com"
BSC_RPC_URL="https://bsc-dataseed.binance.org,https://bsc-rpc.publicnode.com"

# Price API Configuration
# CoinGecko is free, optional API key for higher limits
COINGECKO_API_KEY=""

# Optional: CoinMarketCap API (for backup price feeds)
COINMARKETCAP_API_KEY=""

# CORS Configuration
FRONTEND_URL="http://localhost:3000"

# Optional: Token Discovery APIs
COVALENT_API_KEY=""
MORALIS_API_KEY=""

# AI Analysis Configuration
# Get API key from OpenAI or Anthropic
OPENAI_API_KEY=""
# Or use Anthropic Claude
ANTHROPIC_API_KEY=""

# Hugging Face API Configuration
# Get free API key from https://huggingface.co/settings/tokens
# Used for AI-powered price forecasting with Chronos model
HUGGINGFACE_API_KEY=""

# Gate.io API Configuration
# Get API credentials from https://www.gate.io/myaccount/apiv4keys
GATE_API_KEY=""
GATE_API_SECRET=""

# Snapshot Scheduler
ENABLE_SNAPSHOT_SCHEDULER="false"

# Development Settings
DEBUG=true
LOG_LEVEL="info"
